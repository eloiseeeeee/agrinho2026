<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nexus - Inovação em Movimento</title>
    <link rel="stylesheet" href="style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
    <!-- HEADER -->
    <header class="header">
        <nav class="nav container">
            <div class="nav__logo">
                <span>NEXUS</span>
            </div>
            
            <div class="nav__menu" id="nav-menu">
                <ul class="nav__list">
                    <li><a href="#home" class="nav__link">Início</a></li>
                    <li><a href="#sobre" class="nav__link">Sobre</a></li>
                    <li><a href="#recursos" class="nav__link">Recursos</a></li>
                    <li><a href="#precos" class="nav__link">Preços</a></li>
                    <li><a href="#contato" class="nav__link">Contato</a></li>
                </ul>
            </div>

            <div class="nav__actions">
                <button class="btn btn--outline" id="btn-login">Entrar</button>
                <button class="btn btn--primary" id="btn-cta">Começar Grátis</button>
            </div>

            <!-- Hamburger -->
            <button class="nav__toggle" id="nav-toggle" aria-label="Toggle menu">
                <i class="fas fa-bars"></i>
            </button>
        </nav>
    </header>

    <!-- HERO -->
    <section id="home" class="hero">
        <div class="container hero__grid">
            <div class="hero__content">
                <h1 class="hero__title">O futuro da <span class="highlight">produtividade</span> está aqui</h1>
                <p class="hero__description">Plataforma inteligente que conecta equipes, automatiza processos e acelera resultados. Projetada para o mundo moderno.</p>
                
                <div class="hero__actions">
                    <button class="btn btn--primary btn--large" id="hero-cta">Experimentar gratuitamente</button>
                    <button class="btn btn--secondary btn--large">
                        <i class="fas fa-play"></i>
                        Ver vídeo (1:32)
                    </button>
                </div>

                <div class="hero__trust">
                    <p>Confiado por equipes em</p>
                    <div class="hero__logos">
                        <span>Stripe</span>
                        <span>Airbnb</span>
                        <span>Notion</span>
                        <span>Intercom</span>
                    </div>
                </div>
            </div>

            <div class="hero__image">
                <img src="https://picsum.photos/id/1015/800/600" alt="Dashboard da Nexus" class="hero__img">
                <div class="hero__floating-card">
                    <div class="floating-card__content">
                        <i class="fas fa-check-circle"></i>
                        <div>
                            <strong>98.4%</strong>
                            <small>de satisfação</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- SOBRE -->
    <section id="sobre" class="section">
        <div class="container">
            <div class="section__header">
                <span class="badge">Por que Nexus?</span>
                <h2>Simples. Poderoso. Intuitivo.</h2>
                <p>Construímos uma plataforma que elimina a complexidade e foca no que realmente importa: resultados.</p>
            </div>

            <div class="grid grid--3">
                <div class="card">
                    <div class="card__icon">
                        <i class="fas fa-bolt"></i>
                    </div>
                    <h3>Velocidade Extrema</h3>
                    <p>Carregamento instantâneo e ações em tempo real. Seu time não vai mais esperar por nada.</p>
                </div>
                <div class="card">
                    <div class="card__icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <h3>Colaboração Real</h3>
                    <p>Edição simultânea, comentários contextuais e comunicação integrada em um só lugar.</p>
                </div>
                <div class="card">
                    <div class="card__icon">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <h3>Segurança Avançada</h3>
                    <p>Enterprise-grade encryption, SSO, e conformidade com GDPR e LGPD.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- RECURSOS -->
    <section id="recursos" class="section section--alt">
        <div class="container">
            <div class="section__header">
                <h2>Recursos que fazem a diferença</h2>
            </div>

            <div class="features">
                <div class="feature">
                    <div class="feature__visual">
                        <img src="https://picsum.photos/id/201/600/400" alt="Automação">
                    </div>
                    <div class="feature__content">
                        <h3>Automação Inteligente</h3>
                        <p>Crie fluxos de trabalho automatizados com IA que aprendem com o comportamento da sua equipe.</p>
                        <ul>
                            <li><i class="fas fa-check"></i> Tarefas recorrentes</li>
                            <li><i class="fas fa-check"></i> Notificações inteligentes</li>
                            <li><i class="fas fa-check"></i> Integrações nativas</li>
                        </ul>
                    </div>
                </div>

                <div class="feature feature--reverse">
                    <div class="feature__visual">
                        <img src="https://picsum.photos/id/237/600/400" alt="Analytics">
                    </div>
                    <div class="feature__content">
                        <h3>Analytics em Tempo Real</h3>
                        <p>Relatórios visuais que mostram exatamente onde sua equipe está ganhando ou perdendo tempo.</p>
                        <ul>
                            <li><i class="fas fa-check"></i> Dashboards personalizáveis</li>
                            <li><i class="fas fa-check"></i> Previsões de desempenho</li>
                            <li><i class="fas fa-check"></i> Exportação em um clique</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- PREÇOS -->
    <section id="precos" class="section">
        <div class="container">
            <div class="section__header">
                <h2>Escolha o plano perfeito</h2>
                <p class="toggle-container">
                    <span class="toggle-label active" id="monthly">Mensal</span>
                    <label class="switch">
                        <input type="checkbox" id="billing-toggle">
                        <span class="slider"></span>
                    </label>
                    <span class="toggle-label" id="yearly">Anual <span class="save">-20%</span></span>
                </p>
            </div>

            <div class="pricing-grid">
                <!-- Plano 1 -->
                <div class="pricing-card">
                    <h3>Iniciante</h3>
                    <div class="price" id="price-starter">
                        <span class="currency">R$</span>29
                        <span class="period">/mês</span>
                    </div>
                    <ul>
                        <li><i class="fas fa-check"></i> Até 5 usuários</li>
                        <li><i class="fas fa-check"></i> 10GB de armazenamento</li>
                        <li><i class="fas fa-check"></i> Suporte por email</li>
                    </ul>
                    <button class="btn btn--outline btn--full">Escolher Plano</button>
                </div>

                <!-- Plano Popular -->
                <div class="pricing-card pricing-card--popular">
                    <div class="popular-badge">Mais Popular</div>
                    <h3>Profissional</h3>
                    <div class="price" id="price-pro">
                        <span class="currency">R$</span>79
                        <span class="period">/mês</span>
                    </div>
                    <ul>
                        <li><i class="fas fa-check"></i> Usuários ilimitados</li>
                        <li><i class="fas fa-check"></i> 500GB de armazenamento</li>
                        <li><i class="fas fa-check"></i> Suporte prioritário 24/7</li>
                        <li><i class="fas fa-check"></i> IA avançada</li>
                    </ul>
                    <button class="btn btn--primary btn--full">Começar Agora</button>
                </div>

                <!-- Plano 3 -->
                <div class="pricing-card">
                    <h3>Enterprise</h3>
                    <div class="price">
                        <span class="custom">Custom</span>
                    </div>
                    <ul>
                        <li><i class="fas fa-check"></i> Tudo do Profissional</li>
                        <li><i class="fas fa-check"></i> SSO &amp; SCIM</li>
                        <li><i class="fas fa-check"></i> Dedicação de conta</li>
                        <li><i class="fas fa-check"></i> SLA 99.99%</li>
                    </ul>
                    <button class="btn btn--outline btn--full">Falar com Vendas</button>
                </div>
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <footer class="footer">
        <div class="container">
            <div class="footer__grid">
                <div>
                    <div class="nav__logo"><span>NEXUS</span></div>
                    <p>Transformando a forma como as equipes trabalham.</p>
                </div>
                
                <div>
                    <h4>Produto</h4>
                    <ul>
                        <li><a href="#">Recursos</a></li>
                        <li><a href="#">Preços</a></li>
                        <li><a href="#">Integrações</a></li>
                    </ul>
                </div>
                
                <div>
                    <h4>Empresa</h4>
                    <ul>
                        <li><a href="#">Sobre nós</a></li>
                        <li><a href="#">Blog</a></li>
                        <li><a href="#">Carreiras</a></li>
                    </ul>
                </div>
                
                <div>
                    <h4>Legal</h4>
                    <ul>
                        <li><a href="#">Privacidade</a></li>
                        <li><a href="#">Termos</a></li>
                    </ul>
                </div>
            </div>
            
            <div class="footer__bottom">
                <p>&copy; 2026 Nexus. Todos os direitos reservados.</p>
                <div class="social">
                    <a href="#"><i class="fab fa-twitter"></i></a>
                    <a href="#"><i class="fab fa-linkedin"></i></a>
                    <a href="#"><i class="fab fa-instagram"></i></a>
                </div>
            </div>
        </div>
    </footer>

    <script src="script.js"></script>
</body>
</html>